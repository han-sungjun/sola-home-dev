{
  "buildCommand": "node replace-env.js",
  "outputDirectory": ".",
  "routes": [
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/app",
      "dest": "/app.html"
    },
    {
      "src": "/admin",
      "dest": "/sola-admin-x92ks.html"
    },
    {
      "src": "/signup",
      "dest": "/signup.html"
    },
    {
      "src": "/phone-verify",
      "dest": "/phone-verify.html"
    },
    {
      "src": "/share/notice/([^/]+)",
      "dest": "/app.html?open=notice&id=$1&from=share"
    },
    {
      "src": "/share/benefit/([^/]+)",
      "dest": "/app.html?open=benefit&id=$1&from=share"
    },
    {
      "src": "/notice/(.*)",
      "dest": "/app.html?open=notice&id=$1"
    },
    {
      "src": "/benefit/(.*)",
      "dest": "/app.html?open=benefit&id=$1"
    },
    {
      "src": "/(.*\\.(js|css|png|jpg|jpeg|gif|svg|ico|json|webmanifest|txt|map|woff|woff2|ttf))",
      "dest": "/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/error.html",
      "status": 404
    }
  ]
}
