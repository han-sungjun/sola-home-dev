{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "routes": [
    {
      "src": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "www.sola-home.kr"
        }
      ],
      "status": 308,
      "headers": {
        "Location": "https://theunjeongpick.com/$1"
      }
    },
    {
      "src": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "sola-home.kr"
        }
      ],
      "status": 308,
      "headers": {
        "Location": "https://theunjeongpick.com/$1"
      }
    },
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/app",
      "dest": "/app.html"
    },
    {
      "src": "/admin",
      "dest": "/admin.html"
    },
    {
      "src": "/signup",
      "dest": "/signup.html"
    },
    {
      "src": "/phone-verify",
      "dest": "/phone-verify.html"
    },
    {
      "src": "/guide",
      "dest": "/guide.html"
    },
    {
      "src": "/guide.html",
      "dest": "/guide.html"
    },
    {
      "src": "/policy",
      "dest": "/policy.html"
    },
    {
      "src": "/policy.html",
      "dest": "/policy.html"
    },
    {
      "src": "/terms",
      "dest": "/terms.html"
    },
    {
      "src": "/terms.html",
      "dest": "/terms.html"
    },
    {
      "src": "/privacy",
      "dest": "/privacy.html"
    },
    {
      "src": "/privacy.html",
      "dest": "/privacy.html"
    },
    {
      "src": "/share/notice/([^/]+)",
      "dest": "/app.html?open=notice&id=$1&from=share"
    },
    {
      "src": "/share/benefit/([^/]+)",
      "dest": "/app.html?open=benefit&id=$1&from=share"
    },
    {
      "src": "/notice/(.*)",
      "dest": "/app.html?open=notice&id=$1"
    },
    {
      "src": "/benefit/(.*)",
      "dest": "/app.html?open=benefit&id=$1"
    },
    {
      "src": "/(.*\\.(js|css|png|jpg|jpeg|gif|svg|ico|json|webmanifest|txt|map|woff|woff2|ttf))",
      "dest": "/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/error.html",
      "status": 404
    }
  ]
}